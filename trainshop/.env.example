# Configuration d'environnement pour TrainShop
# Copie ce fichier vers .env et adapte les valeurs si besoin

# Base de données PostgreSQL
POSTGRES_USER=trainer
POSTGRES_PASSWORD=trainshop_dev_only
POSTGRES_DB=trainshop

# Ports d'exposition (sur localhost)
WEB_PORT=8080
API_PORT=3000

# Environnement Node.js
NODE_ENV=production

# Redis (cache)
REDIS_URL=redis://cache:6379

# Timezone (optionnel)
TZ=Europe/Paris
